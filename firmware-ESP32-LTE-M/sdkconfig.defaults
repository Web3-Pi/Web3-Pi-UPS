# Defaults for the LilyGo T-SIM7080G-S3 board (ESP32-S3-WROOM-1, 16 MB Flash, OPI PSRAM).
# Delete sdkconfig if you want a clean rebuild from these defaults.

# --- Console (USB-Serial-JTAG over USB-C) ---
CONFIG_ESP_CONSOLE_USB_SERIAL_JTAG=y

# --- Logging ---
CONFIG_LOG_DEFAULT_LEVEL_INFO=y

# --- lwIP: enable PPP so esp_modem can attach the cellular modem as a netif ---
CONFIG_LWIP_PPP_SUPPORT=y
CONFIG_LWIP_PPP_PAP_SUPPORT=y
CONFIG_LWIP_PPP_CHAP_SUPPORT=y
CONFIG_LWIP_PPP_NOTIFY_PHASE_SUPPORT=y

# --- Flash size (board has 16 MB) ---
CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y

# --- TLS: use the mbedTLS-bundled root CA store so esp-mqtt can verify
#         broker.w3p.ovh's Let's Encrypt cert without us having to embed
#         certs ourselves. ---
CONFIG_MBEDTLS_CERTIFICATE_BUNDLE=y
CONFIG_MBEDTLS_CERTIFICATE_BUNDLE_DEFAULT_FULL=y

# Allocate mbedTLS handshake buffers on the heap instead of the stack.
# Without this the per-task stack must be huge to fit a TLS 1.2/1.3
# handshake, which manifests as an X509 fatal error during connect.
CONFIG_MBEDTLS_DYNAMIC_BUFFER=y

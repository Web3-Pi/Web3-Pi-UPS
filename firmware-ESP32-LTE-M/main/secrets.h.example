#pragma once

/*
 * Local secrets file — copy to secrets.h and fill in. secrets.h is
 * gitignored so credentials never end up in the repo.
 *
 *   cp main/secrets.h.example main/secrets.h
 *   $EDITOR main/secrets.h
 */

/* MQTT broker URI. For TLS use the mqtts:// scheme — esp-mqtt then
 * negotiates TLS using the CA bundle configured in sdkconfig. */
#define MQTT_BROKER_URI    "mqtts://broker.w3p.ovh:8883"

#define MQTT_USERNAME      "TestUpsUser"
#define MQTT_PASSWORD      "REPLACE_ME"
